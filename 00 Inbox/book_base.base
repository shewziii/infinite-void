views:
  - type: cards
    name: Table
    filters:
      and:
        - file.inFolder("30 Hobbies/Books")
        - '!file.hasTag("book/highlights")'
    order:
      - file.name
      - author
    sort:
      - property: series
        direction: ASC
    image: note.cover
    imageAspectRatio: 1.55
    cardSize: 170
